# Server
PORT=3000
NODE_ENV=development

# Storage paths (relative to project root)
UPLOAD_TMP_DIR=./data/uploads
EXTRACT_TMP_DIR=./data/extracted
DB_PATH=./data/app.db

# Upload limits
MAX_UPLOAD_BYTES=262144000          # 250 MB
MAX_DECOMPRESSED_BYTES=1073741824   # 1 GB hard cap to defend against zip bombs
MAX_ZIP_ENTRIES=20000

# Rate limiting (uploads per IP per window)
UPLOAD_RATE_WINDOW_MS=900000        # 15 minutes
UPLOAD_RATE_MAX=10
