run = "npm run start"
entrypoint = "server/dist/index.js"

[nix]
channel = "stable-24_05"

[deployment]
run = ["sh", "-c", "npm run start"]
build = ["sh", "-c", "npm run install:all && npm run build"]
deploymentTarget = "cloudrun"

[[ports]]
localPort = 3000
externalPort = 80

[env]
PORT = "3000"
NODE_ENV = "production"

[agent]
expertMode = true
